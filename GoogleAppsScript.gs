const SPREADSHEET_ID = "REEMPLAZA_CON_EL_ID_DE_TU_GOOGLE_SHEET";
function doPost(e){try{const d=JSON.parse(e.postData.contents);const ss=SpreadsheetApp.openById(SPREADSHEET_ID);const s=getSheet(ss,"Solicitudes",["IDSolicitud","Fecha","Solicitante","Correo","Área","Sucursal","Estatus","Observaciones"]);const det=getSheet(ss,"DetalleSolicitud",["IDDetalle","IDSolicitud","IDProducto","Producto","Categoría","Cantidad","Unidad"]);const lock=LockService.getScriptLock();lock.waitLock(30000);try{s.appendRow([d.requestId,new Date(d.submittedAt),d.requester.fullName,d.requester.email,d.requester.area,d.requester.branch,"Recibida",d.notes||""]);d.products.forEach((p,i)=>det.appendRow([`${d.requestId}-DET-${String(i+1).padStart(3,"0")}`,d.requestId,p.productId,p.productName,p.category,p.quantity,p.unit]));}finally{lock.releaseLock()}return out({ok:true,requestId:d.requestId})}catch(err){return out({ok:false,message:err.message})}}
function doGet(){return out({ok:true,service:"SGSA API"})}
function getSheet(ss,n,h){let sh=ss.getSheetByName(n);if(!sh){sh=ss.insertSheet(n);sh.appendRow(h);sh.getRange(1,1,1,h.length).setFontWeight("bold");sh.setFrozenRows(1)}return sh}
function out(x){return ContentService.createTextOutput(JSON.stringify(x)).setMimeType(ContentService.MimeType.JSON)}
